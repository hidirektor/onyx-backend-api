{
  "name": "onyx-backend-api",
  "version": "1.0.0",
  "description": "Onyx API Gateway - Module-based Backend API Architecture",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit"
  },
  "_moduleAliases": {
    "@core": "app/core",
    "@infrastructure": "app/core/infrastructure",
    "@shared": "app/shared",
    "@modules": "app/modules",
    "@services": "app/services",
    "@database": "app/core/domain/database"
  },
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "amqplib": "^0.10.3",
    "bcrypt": "^6.0.0",
    "body-parser": "2.2.2",
    "celebrate": "^15.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "ejs": "^5.0.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "geoip-lite": "^2.0.0",
    "http-status-codes": "^2.3.0",
    "ioredis": "^5.10.0",
    "joi": "^18.0.2",
    "jsdom": "^29.0.0",
    "jsonwebtoken": "^9.0.3",
    "ldapjs": "^3.0.7",
    "minio": "^8.0.7",
    "module-alias": "^2.3.4",
    "moment-timezone": "^0.6.0",
    "mssql": "^12.2.0",
    "multer": "2.1.1",
    "mysql2": "^3.19.1",
    "node-cron": "^4.2.1",
    "nodemailer": "8.0.2",
    "pdfkit": "^0.18.0",
    "qrcode": "^1.5.3",
    "require-directory": "^2.1.1",
    "sequelize": "^6.37.8",
    "sequelize-cli": "^6.6.3",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "clinic": "^13.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.1.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/*.test.js"],
    "moduleNameMapper": {
      "^@core/(.*)$": "<rootDir>/app/core/$1",
      "^@infrastructure/(.*)$": "<rootDir>/app/core/infrastructure/$1",
      "^@shared/(.*)$": "<rootDir>/app/shared/$1",
      "^@modules/(.*)$": "<rootDir>/app/modules/$1",
      "^@services/(.*)$": "<rootDir>/app/services/$1",
      "^@database/(.*)$": "<rootDir>/app/core/domain/database/$1"
    }
  },
  "keywords": [],
  "author": "hidirektor - Halil İbrahim Direktör",
  "license": "ISC"
}
