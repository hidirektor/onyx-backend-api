# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=2805
CORS_ORIGIN=*
LOG_LEVEL=verbose

# ─── MySQL Database ────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=onyx_db
DB_USER=root
DB_PASS=
DB_LOGGING=false
DB_POOL_MAX=10
DB_POOL_MIN=0

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads

# ─── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ─── Mail (SMTP) ───────────────────────────────────────────────────────────────
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@onyx.app
MAIL_FROM_NAME=Onyx

# ─── Geo Protection ────────────────────────────────────────────────────────────
# GEO_PROTECTION_ENABLED=true
# GEO_PROTECTION_MODE=whitelist        # whitelist | blacklist | off
# GEO_WHITELIST=TR                     # Comma-separated ISO 3166-1 alpha-2 codes
# GEO_BLACKLIST=                       # Used when mode=blacklist
# GEO_BLOCK_VPN=true
# GEO_BLOCK_PROXY=true
# GEO_TRUSTED_IPS=127.0.0.1,::1       # Always-allowed IPs (your servers, CI, etc.)

# ─── JWT ───────────────────────────────────────────────────────────────────────
# IMPORTANT: Use long, random secrets in production (e.g. openssl rand -base64 64)
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=1d
