# ─── Application ──────────────────────────────────────────────────────────────
APP_VERSION=1.0.0
NODE_ENV=development
PORT=2805
CORS_ORIGIN=*
LOG_LEVEL=info

# ============================================
# MySQL/MariaDB Database Configuration
# ============================================
MYSQL_DB_HOST=localhost
MYSQL_DB_NAME=project_onyx
MYSQL_DB_USERNAME=project_onyx_mariadb
MYSQL_DB_PASSWORD=
MYSQL_DB_PORT=3306
MYSQL_DB_LOGGING=false
MYSQL_DB_POOL_MAX=10
MYSQL_DB_POOL_MIN=0

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=
RABBITMQ_VHOST=/
RABBITMQ_USE_SSL=false
RABBITMQ_HEARTBEAT=60
RABBITMQ_CONNECTION_TIMEOUT=30000

# ============================================
# MinIO/S3 Configuration
# ============================================
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_BUCKET_NAME=project-onyx-backend
# New format (preferred):
MINIO_USERNAME=
MINIO_PASSWORD=
# Legacy format (also supported):
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# ============================================
# Resend Email Configuration
# ============================================
RESEND_SMTP_HOST=smtp.resend.com
RESEND_SMTP_PORT=465
RESEND_SMTP_USER=resend
RESEND_SMTP_PASS=
RESEND_SMTP_FROM=noreply@example.com
# RESEND_SMTP_FROM_NAME=Onyx


# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Use long, random secrets in production (e.g. openssl rand -base64 64)
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
